# VoiceApp — Required Environment Variables
# Copy this file to .env and fill in all values before running the server.
# The server will refuse to start if any of these are missing.

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Twilio WhatsApp
# Account SID and Auth Token: https://console.twilio.com → Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Your Twilio WhatsApp number in E.164 format (sandbox: +14155238886)
# Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_WHATSAPP_NUMBER=+14155238886

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (BullMQ)
REDIS_URL=

# API Security
API_BEARER_TOKEN=

# Frontend (optional — defaults to http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# Google Maps (Phase 06.1 — Verbose Navigation)
GOOGLE_MAPS_API_KEY=

# ElevenLabs multilingual voice IDs (Phase 06.1 — Translation + Podcasts)
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_AF=
ELEVENLABS_VOICE_ID_ZU=
ELEVENLABS_VOICE_ID_XH=
ELEVENLABS_VOICE_ID_ST=
