# ═══════════════════════════════════════════════════════════════════════════════
# VoiceApp — Environment Variables
# Copy this file to .env and fill in all required values.
# The server refuses to start if required variables are missing.
# ═══════════════════════════════════════════════════════════════════════════════

# ── AI: Claude (orchestrator + NLP) ────────────────────────────────────────────
# https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# ── AI: OpenAI (TTS + embeddings) ──────────────────────────────────────────────
# Two uses: text-to-speech (tts-1 model) and memory embeddings (text-embedding-3-small)
# https://platform.openai.com/api-keys → Create new secret key
OPENAI_API_KEY=sk-...

# Optional: override TTS voices (OpenAI voice names: alloy ash coral echo fable nova onyx sage shimmer)
# Defaults are fine — only set these to change the agent/podcast voices
OPENAI_TTS_VOICE_AGENT=nova
OPENAI_TTS_VOICE_THABO=onyx
OPENAI_TTS_VOICE_NALEDI=nova

# ── Web search (podcast research + WebSearch tool) ─────────────────────────────
# https://app.tavily.com → API Keys → Generate
TAVILY_API_KEY=tvly-...

# ── WhatsApp via Twilio ─────────────────────────────────────────────────────────
# Dashboard → Account Info: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Your Twilio WhatsApp-enabled number in E.164 format
# Sandbox number (free, no approval needed): +14155238886
# Sandbox setup: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Supabase ────────────────────────────────────────────────────────────────────
# Project Settings → API: https://supabase.com/dashboard/project/_/settings/api
# URL: "Project URL"  |  Key: "service_role" (not anon — service_role bypasses RLS)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Security ────────────────────────────────────────────────────────────────────
# Arbitrary secret shared between frontend and backend for API bearer auth.
# Generate with: openssl rand -hex 32
API_BEARER_TOKEN=

# ── ngrok (optional — local dev tunnelling for Twilio webhooks) ─────────────────
# Required only for local dev so Twilio can reach your machine over the internet.
# Free account at https://dashboard.ngrok.com/get-started/your-authtoken
# When set, server logs the public URL on startup.
NGROK_AUTHTOKEN=

# ── CORS / frontend origin ──────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── Redis (optional — powers BullMQ heartbeat + cron workers) ──────────────────
# Required only if you want the WhatsApp heartbeat worker and morning briefing cron.
# The server boots and handles voice commands without Redis.
# Local: redis://localhost:6379
# Upstash free tier: https://upstash.com (no local install needed)
REDIS_URL=redis://localhost:6379
