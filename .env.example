# VoiceApp — Required Environment Variables
# Copy this file to .env and fill in all values before running the server.
# The server will refuse to start if any of these are missing.

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (BullMQ)
REDIS_URL=

# API Security
API_BEARER_TOKEN=

# Frontend (optional — defaults to http://localhost:5173)
# FRONTEND_ORIGIN=
